# Configuration for invite_users.py
# Copy to .env and fill with real values (.env is gitignored)

# Base URL of the n8n instance (no trailing slash)
N8N_BASE_URL=http://localhost:5678

# Instance owner credentials, used to log in via the REST API
N8N_OWNER_EMAIL=owner@example.com
N8N_OWNER_PASSWORD=change-me
