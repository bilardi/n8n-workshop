flowchart TD
    N1["Nodo 1
    (Schedule Trigger)"]
    N2["Nodo 2
    (HTTP Request: getUpdates)"]
    N3["Nodo 3
    (Code: filtro ultimo messaggio)"]
    N4["Nodo 4
    (Switch)"]
    HA["HTTP Request
    (n8n API: executions)"]
    RD["Read File from Disk
    (last_run.json)"]
    CVT["Convert from File
    (Extract JSON)"]
    MG["Merge
    (Append)"]
    CC["Code: formatta messaggio"]
    D["Nodo F
    (Telegram: Send Message)"]
    N5["Nodo 5
    (IF: regex)"]
    N6["Nodo 6
    (Telegram: Send Message)"]

    N1 --> N2 --> N3 --> N4
    N4 -->|"/status"| HA --> MG
    N4 -->|"/status"| RD --> CVT --> MG
    MG --> CC --> D
    N4 -->|"fallback"| N5 -->|true| N6
