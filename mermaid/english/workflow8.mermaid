flowchart TD
    N1["Node 1
    (Schedule Trigger)"]
    N2["Node 2
    (HTTP Request: getUpdates)"]
    N3["Node 3
    (Code: filter latest message)"]
    N4["Node 4
    (Switch)"]
    HA["HTTP Request
    (n8n API: executions)"]
    RD["Read File from Disk
    (last_run.json)"]
    CVT["Convert from File
    (Extract JSON)"]
    MG["Merge
    (Append)"]
    CC["Code: format message"]
    D["Node F
    (Telegram: Send Message)"]
    N5["Node 5
    (IF: regex)"]
    N6["Node 6
    (Telegram: Send Message)"]

    N1 --> N2 --> N3 --> N4
    N4 -->|"/status"| HA --> MG
    N4 -->|"/status"| RD --> CVT --> MG
    MG --> CC --> D
    N4 -->|"fallback"| N5 -->|true| N6
